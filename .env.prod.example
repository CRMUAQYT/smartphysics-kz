# ─────────────────────────────────────────────────────────────
# Production environment for the Hetzner server.
# Copy to .env.prod and fill in real values, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
# ─────────────────────────────────────────────────────────────

# Public HTTPS hostname for the API (sslip.io maps the IP to a real DNS name so
# Let's Encrypt can issue a certificate). Format: <ip-with-dashes>.sslip.io
API_DOMAIN=178-105-152-178.sslip.io

# Postgres password (choose something strong)
DB_PASSWORD=change_me_strong_db_password

# JWT secrets — generate with:  openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_generate_32_byte_hex
JWT_REFRESH_SECRET=change_me_another_32_byte_hex

# CORS: the exact origin of the frontend (GitHub Pages).
# It is the ORIGIN only (no path): https://<your-github-username>.github.io
CLIENT_URL=https://YOUR_GITHUB_USERNAME.github.io

# Admin account created/updated by the seed on first boot
ADMIN_EMAIL=gggsayat2004@gmail.com
ADMIN_PASSWORD=SmartPhysics2026!
ADMIN_NAME=Сайат Админ
